# Core API
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

# OpenAI-compatible inference endpoint, for example vLLM or llama.cpp server
OPENAI_BASE_URL=http://localhost:8001/v1
OPENAI_API_KEY=local-dev-key
DEFAULT_CHAT_MODEL=qwen-local
SMALL_MODEL=qwen-4b
CODING_MODEL=deepseek-coder-local
LONG_CONTEXT_MODEL=qwen-long-context

# Retrieval and ranking
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=llms101_docs
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large

# Storage and queues
POSTGRES_USER=llms101
POSTGRES_PASSWORD=llms101
POSTGRES_DB=llms101
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql://llms101:llms101@localhost:5432/llms101
REDIS_URL=redis://localhost:6379/0
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Auth and observability
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
PROMETHEUS_PORT=9108

# Local inference
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
GGUF_MODEL_PATH=models/gguf/model.gguf
SGLANG_MODEL=Qwen/Qwen2.5-7B-Instruct
SGLANG_PORT=8002
